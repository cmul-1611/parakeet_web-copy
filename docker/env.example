# Copy this file as .env in the ./docker folder:
#   cp docker/env.example docker/.env
# Then edit docker/.env with your own values.

# Analytics Configuration (optional - remove or leave empty to disable)
VITE_ANALYTICS_URL=https://your-umami-instance.com/getinfo
VITE_ANALYTICS_WEBSITE_ID=your-website-id-here

# Optional Subresource Integrity hash for the analytics script. Strongly
# recommended when umami is hosted on a third-party SaaS or any host outside
# the operator's direct control: if that host is ever compromised or the
# account taken over, a tampered script would otherwise run in the parakeet
# origin with full DOM access (transcripts, microphone audio). When this
# hash is set, the browser refuses to execute a mismatched script.
# Compute with: curl -fsSL "$VITE_ANALYTICS_URL" | openssl dgst -sha384 -binary | openssl base64 -A
# Then set: VITE_ANALYTICS_SRI=sha384-<base64>
# Remember to update the hash whenever umami is upgraded.
# VITE_ANALYTICS_SRI=

# Dictation device support (Philips SpeechMike via WebHID).
# Set to false to hide the "Connect Dictation Device" button.
# Default: true
VITE_DICTATION_DEVICE_SUPPORT=true

# Model Configuration.
# Default: istupakov/parakeet-tdt-0.6b-v3-onnx
VITE_MODEL_REPO=istupakov/parakeet-tdt-0.6b-v3-onnx

# Pin the model files to a specific HuggingFace git commit SHA. Without a
# pin, the app fetches from the moving 'main' branch: a repo takeover or
# force-push by a compromised maintainer would silently swap weights for
# every visitor, and an attacker-crafted ONNX runs in WASM/WebGPU with
# full access to user microphone audio.
# Recommended workflow (one-shot, on a trusted network):
#   REPO=istupakov/parakeet-tdt-0.6b-v3-onnx
#   SHA=$(curl -fsSL "https://huggingface.co/api/models/$REPO/revision/main" | jq -r .sha)
#   echo "revision: '$SHA'"
#   curl -fsSL "https://huggingface.co/api/models/$REPO/revision/$SHA" \
#     | jq -r '.siblings[].rfilename' \
#     | while read f; do
#         H=$(curl -fsSL "https://huggingface.co/$REPO/resolve/$SHA/$f" | sha256sum | awk '{print $1}')
#         printf "  '%s': '%s',\n" "$f" "$H"
#       done
# Paste the resulting `revision` + `hashes` block into app/src/models.js
# for the matching model entry, commit, and redeploy. Once pinned there,
# VITE_MODEL_REVISION below can stay unset. Alternatively set it to
# override at runtime (useful for emergency repins without a redeploy).
# When neither models.js nor this env var pins a SHA, the browser console
# logs a loud warning and integrity verification is skipped.
# Default: (unset, uses per-model pin in models.js)
# VITE_MODEL_REVISION=

# Local model fallback: serve weights from a host folder bind-mounted into
# the container so the app works even when HuggingFace is unreachable.
#
# 1. Pre-populate the host folder with the ONNX files (flat layout):
#      hf download istupakov/parakeet-tdt-0.6b-v3-onnx --local-dir /host/path
# 2. Add a volume in docker-compose.yml mapping that host folder to an
#    in-container path, e.g. `- /host/path:/models:ro`.
# 3. Set LOCAL_MODEL_PATH below to the matching in-container path.
#
# Caddy serves whatever is at LOCAL_MODEL_PATH under /models/. The container
# crashes at startup if vocab.txt isn't found there.
# Default: (unset — local fallback feature disabled)
# LOCAL_MODEL_PATH=/models
#
# VITE_LOCAL_MODEL_FALLBACK is auto-enabled when LOCAL_MODEL_PATH is set.
# Override explicitly if needed.
# Default: (unset — auto-derived: "true" when LOCAL_MODEL_PATH is set, otherwise empty)
# VITE_LOCAL_MODEL_FALLBACK=true
#
# Force local fallback: when set to "true", the UI skips HuggingFace entirely
# and always loads model weights from /models/. Useful for troubleshooting
# the local-fallback path without simulating a blocked HF. Implies
# VITE_LOCAL_MODEL_FALLBACK=true.
# Default: (unset — equivalent to false)
# VITE_FORCE_LOCAL_MODEL_FALLBACK=true

# Development mode: shows a warning banner to visitors when set to true.
# Default: false
# VITE_DEV_MODE=true

# F-99: production refuses to load model weights with no pinned hashes
# in app/src/models.js (and no VITE_MODEL_REVISION override). The pinning
# recipe in env.example (sha256 of every weight file at a specific HF
# commit) is the supported path. If you understand the risk and want to
# accept trust-on-first-use (e.g. for a private deployment where you've
# already verified the upstream out of band), set this to "true" to
# unlock the legacy warn-and-proceed behaviour.
# When combined with LOCAL_MODEL_PATH, this opt-in also skips runtime
# hash verification for the bind-mounted weights. Only safe if the host
# folder is trusted (ideally a read-only mount), since a poisoned
# bind-mount will be served without challenge. The entrypoint logs a
# warning so this configuration is visible in `docker logs`.
# Default: (unset, prod refuses to load)
# VITE_ALLOW_UNVERIFIED_MODEL=true

# Dictation regex source: override the default Murmure-regex GitLab URL.
# Can be a GitLab-compatible repo URL or a local folder path containing CSV regex files.
# Examples:
#   DICTATION_REGEX_SOURCE=https://framagit.org/interhop/murmure-regex
#   DICTATION_REGEX_SOURCE=/path/to/my/regex-csvs
# Default: https://framagit.org/interhop/murmure-regex
# DICTATION_REGEX_SOURCE=

# ============ Remote Microphone (Phone as Mic via WebRTC) ============
# The "Phone as Microphone" feature lets users scan a QR code on their phone
# to stream audio (E2E encrypted with ECDH + AES-GCM) over WebRTC to the
# computer running ParakeetWeb for transcription.
#
# How it works:
#   1. An Express signaling server (port 3001) handles WebRTC offer/answer
#      relay and generates ephemeral TURN credentials.
#   2. The phone opens /remote-mic.html, captures the mic, encrypts PCM
#      audio, and sends it over a WebRTC data channel.
#   3. The computer decrypts, resamples to 16kHz, and feeds the audio into
#      the normal ASR pipeline.
#
# The signaling server starts automatically when /signaling/server.js is
# present (mounted in docker-compose.yml). Without TURN_SERVER set, it
# still works on a local network (STUN-only / direct P2P). For use over
# the internet you need a TURN relay — either the coturn service in
# docker-compose.yml, or an existing coturn instance (e.g. from WebSend).
# If sharing coturn with WebSend, use the same TURN_SECRET value.

# STUN/TURN server (host:port) — must match your coturn configuration
# STUN_SERVER=yourdomain.com:3478
# TURN_SERVER=yourdomain.com:3478

# Shared secret for HMAC-SHA1 ephemeral TURN credentials.
# Must match coturn's --static-auth-secret value.
# TURN_SECRET=your-secret-here

# Lifetime of generated TURN credentials in seconds.
# Default: 3600 (1 hour)
# TURN_CREDENTIAL_TTL=3600

# ICE gathering timeout (seconds) before giving up on TURN candidates.
# Default: 15
# TURN_TIMEOUT=15

# Append Google's public STUN servers to the ICE config as a fallback.
# Set to "false" to rely only on STUN_SERVER / TURN_SERVER you configured.
# Default: true
# STUN_GOOGLE_FALLBACK=true

# TURNS (TURN-over-TLS) port — only needed if coturn has TLS enabled
# TURNS_PORT=8443

# External IP for coturn (only if using the bundled coturn service).
# Must be a public IP, NOT a hostname — coturn cannot resolve DNS here.
# TURN_EXTERNAL_IP=203.0.113.1

# Signaling server port inside the container.
# Default: 3001
# SIGNALING_PORT=3001

# Allowed origins for the signaling server (comma-separated).
# REQUIRED: each entry must include the scheme (http:// or https://).
# The server will refuse to start if this is unset or any entry lacks a scheme.
# ALLOWED_ORIGINS=https://pw.yourdomain.com

# ============ CSP escape hatches ============
# The Caddyfile ships a strict default-deny Content-Security-Policy.
#
# Two pieces are derived automatically by entrypoint.sh and do NOT need
# to be repeated below:
#   - The analytics origin: if VITE_ANALYTICS_URL is set, its
#     https://host[:port] is auto-appended to BOTH script-src and
#     connect-src. Setting the analytics URL is enough; you do not also
#     have to list it in VITE_CSP_*_HOSTS.
#   - The HuggingFace connect-src block (huggingface.co plus the
#     cdn-lfs.* / cas-bridge.xethub.hf.co LFS subdomains) is ON by
#     default and is dropped entirely when
#     VITE_FORCE_LOCAL_MODEL_FALLBACK=true, since the app never reaches
#     HF in that mode.
#
# The env vars below are escape hatches on top of those defaults. Use
# them when HF rotates a CDN subdomain (it does, every few months), to
# allowlist a custom dictation regex CSV host, or to add any other
# origin you trust. Each entry must include the scheme (https://...).
#
# Strict format (entrypoint.sh refuses to start otherwise, F-91):
#   - space-separated tokens
#   - each token MUST be a literal https:// origin
#   - allowed characters: A-Z a-z 0-9 : / . - (and the separator space)
#   - forbidden anywhere in the value: quotes, semicolons, '*',
#     'unsafe-*', 'data:', 'blob:', backticks, $, whitespace other
#     than the ASCII single space
# The validator refuses to start on any operator typo so a stray ';'
# or wildcard can't silently widen the CSP into a fully open policy.
# Default: (unset, only the baked-in HF allowlist applies)
# VITE_CSP_CONNECT_HOSTS=https://cdn-lfs-new.huggingface.co

# Same shape and same validation rules as VITE_CSP_CONNECT_HOSTS, but
# for script-src. Note: the analytics origin from VITE_ANALYTICS_URL is
# already auto-added to script-src by entrypoint.sh, so you only need
# this if you load extra scripts from a host that is neither 'self' nor
# the analytics origin. Default: (unset).
# VITE_CSP_SCRIPT_HOSTS=

# ============ HSTS ============
# The in-container Caddy emits Strict-Transport-Security as belt-and-braces
# if the outer reverse proxy misses it. The default lifetime is two years
# (matches Chrome/Firefox HSTS preload-list requirements); override if you
# need a shorter window during initial roll-out.
# VITE_HSTS_MAX_AGE=63072000
#
# DO NOT enable includeSubDomains unless you control EVERY subdomain of
# the apex and they ALL serve HTTPS. Enabling it permanently forbids
# plain HTTP across the apex for any visitor who opens parakeet once,
# and clients can only undo HSTS manually (chrome://net-internals/#hsts).
# To opt in, set the suffix verbatim (semicolon and leading space matter):
# VITE_HSTS_SUFFIX="; includeSubDomains"
# Adding "; preload" requires submitting the apex to
# https://hstspreload.org first and the entry is irrevocable.
# VITE_HSTS_SUFFIX=

# ============ Reproducible build ============
# The Dockerfile honours SOURCE_DATE_EPOCH for any embedded timestamp and
# emits dist/.well-known/build-sums.txt listing the sha256 of every file
# the runtime image ships. Operators with a git checkout can verify the
# live site against an independent rebuild:
#
#   export SOURCE_DATE_EPOCH=$(git log -1 --format=%ct)
#   sudo docker compose -f docker/docker-compose.yml build
#   sudo docker run --rm parakeetweb cat /srv/.well-known/build-sums.txt > local-sums.txt
#   curl -fsSL https://pw.yourdomain.com/.well-known/build-sums.txt > remote-sums.txt
#   diff local-sums.txt remote-sums.txt && echo OK
#
# If diff prints nothing the live deploy matches the source at this commit.
# Any difference means the server is shipping bytes that don't come from
# this git tree (compromised build pipeline, manual edit on the box, etc.)
# and warrants investigation. Default 0 keeps the build deterministic
# without a git checkout but loses the "matches commit X" property.
#
# F-113: this verification recipe catches an HONEST server publishing
# its own legitimate manifest. It does NOT catch an attacker who fully
# controls the serving host and publishes a TAMPERED manifest that
# omits files they added or rewrites hashes to match their swapped
# bytes (the operator's local-sums.txt and the remote-sums.txt are
# both just text and a diff cannot tell which is canonical). For an
# out-of-band trust anchor, sign build-sums.txt with a maintainer
# GPG key at release time and publish the detached signature in the
# git repo; operators then verify the signature against the public
# key before trusting the diff result. A full sigstore-style
# transparency log is out of scope for this single-maintainer
# project. The mechanism is still useful: it catches accidental
# drift (manual hot-fixes on the box, stale rebuilds, CI race
# conditions) and any attacker who didn't think to rewrite the
# manifest, which is most of them.
# SOURCE_DATE_EPOCH=

# ============ Build-time security ============
# Run `npm audit --audit-level=high` during `docker build` and fail the build
# on any high-severity vulnerability. Set to false to opt out (e.g. when a
# known CVE has been triaged but is not yet patched upstream).
# Default: true
# RUN_NPM_AUDIT=true
