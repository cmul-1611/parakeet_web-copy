# Copy this file as .env in the ./docker folder:
#   cp docker/env.example docker/.env
# Then edit docker/.env with your own values.

# Vite Development Server Configuration
VITE_ALLOWED_HOST=your-domain.com,your-other-domain.com
VITE_USE_POLLING=true

# Analytics Configuration (optional - remove or leave empty to disable)
VITE_ANALYTICS_URL=https://your-umami-instance.com/getinfo
VITE_ANALYTICS_WEBSITE_ID=your-website-id-here

# HuggingFace token (optional): enables gated/private models and faster downloads
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dictation device support (Philips SpeechMike via WebHID)
# Set to false to hide the "Connect Dictation Device" button
VITE_DICTATION_DEVICE_SUPPORT=true

# Model Configuration
VITE_MODEL_REPO=istupakov/parakeet-tdt-0.6b-v3-onnx

# Local model fallback: bake model weights into the Docker image so the app
# works even when HuggingFace is unreachable.  Set to a HF repo ID and rebuild.
# The build will fail if the download fails — no silent surprises at runtime.
# FALLBACK_MODEL_REPO=istupakov/parakeet-tdt-0.6b-v3-onnx
#
# VITE_LOCAL_MODEL_FALLBACK is auto-enabled when FALLBACK_MODEL_REPO is set.
# Override explicitly if needed:
# VITE_LOCAL_MODEL_FALLBACK=true

# Development mode: shows a warning banner to visitors when set to true
# VITE_DEV_MODE=true

# Dictation regex source: override the default Murmure-regex GitLab URL.
# Can be a GitLab-compatible repo URL or a local folder path containing CSV regex files.
# Defaults to https://framagit.org/interhop/murmure-regex
# Examples:
#   DICTATION_REGEX_SOURCE=https://framagit.org/interhop/murmure-regex
#   DICTATION_REGEX_SOURCE=/path/to/my/regex-csvs
# DICTATION_REGEX_SOURCE=
