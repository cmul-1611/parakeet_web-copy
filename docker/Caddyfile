# Caddyfile for parakeetweb production image.
# Serves the built Vite bundle from /srv and proxies signaling traffic to the
# in-container Node sidecar started by entrypoint.sh.

{
	# Caddy admin API isn't needed for this single-process container.
	admin off
	persist_config off
}

:5173 {
	# F-77: compress static assets but NOT /api/signal/*. Today no
	# signaling response reflects the X-Room-Secret header into the
	# body, but a single future debug-echo line (e.g.
	# `res.json({ error, received: req.headers['x-room-secret'] })`)
	# would turn this back into a classic BREACH oracle: same-origin
	# attacker code could measure compressed response sizes to recover
	# the secret byte-by-byte. Signaling JSON is < 2 KB; the bandwidth
	# saving is negligible, the foot-gun isn't.
	@compress not path /api/signal/*
	encode @compress zstd gzip

	# Cross-origin isolation (SharedArrayBuffer / WebGPU / ONNX wasm) plus a
	# strict default-deny Content-Security-Policy. The CSP forbids inline
	# scripts (eruda loader is externalised + SRI), allows 'wasm-unsafe-eval'
	# because ONNX Runtime Web needs it, and keeps style-src 'unsafe-inline'
	# until the JSX inline-style migration in a later round. Connect-src
	# allows the HuggingFace model fetch path and an operator-configurable
	# allowlist via VITE_CSP_CONNECT_HOSTS (umami analytics origin, custom
	# dictation regex CSV host, etc.). Script-src likewise extensible via
	# VITE_CSP_SCRIPT_HOSTS when umami is enabled.
	#
	# The HF connect-src list is the explicit set of subdomains HF
	# currently redirects model files through (cas-bridge.xethub.hf.co for
	# xet-based LFS, cdn-lfs.* for the older S3-backed path). It used to
	# be `*.huggingface.co *.hf.co`, but a wildcard would also match any
	# future HF-controlled subdomain (including user-controllable ones, if
	# HF ever opens that namespace) and turn an XSS in the parakeet origin
	# into an exfil channel through that subdomain. If HF rotates the CDN
	# host, an operator can extend the list at runtime via
	# VITE_CSP_CONNECT_HOSTS without rebuilding the image.
	header {
		# F-71: strip Caddy's default `Server: Caddy` response header so the
		# reverse-proxy identity (and indirectly its version range, pinned
		# by digest in Dockerfile) does not advertise itself to drive-by
		# scanners (Shodan / ZoomEye / mass CVE probers). Free defense in
		# depth; the deploy is still fingerprintable by /.well-known/
		# build-sums.txt for anyone targeting parakeet specifically, but
		# noise reduction for untargeted scans costs nothing here.
		-Server
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Embedder-Policy "require-corp"
		# F-96: dropped `data:` from img-src and font-src. No first-
		# party code emits data: URLs (vite.config.js assetsInlineLimit
		# is set to 0 to keep it that way). data: in img-src is a known
		# CSS-injection-chained exfil channel via SVG; data: in font-src
		# feeds CSS-position-leak via custom-font glyph timing. Both are
		# unneeded.
		# F-97: dropped `blob:` from child-src. No iframes / frames /
		# blob-targeted nested browsing contexts exist in the codebase
		# (only AudioWorklet.addModule and ORT's WASM/MJS loader use
		# blob: URLs, and those fall under worker-src). child-src is
		# tightened to 'none' to match frame-ancestors 'none'.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' {$VITE_CSP_SCRIPT_HOSTS:}; style-src 'self' 'unsafe-inline'; img-src 'self' blob:; media-src 'self' blob:; font-src 'self'; connect-src 'self' https://huggingface.co https://cdn-lfs.huggingface.co https://cdn-lfs-us-1.huggingface.co https://cdn-lfs-eu-1.huggingface.co https://cas-bridge.xethub.hf.co {$VITE_CSP_CONNECT_HOSTS:}; worker-src 'self' blob:; child-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests"
		# Permissions-Policy: only microphone, hid (WebHID for SpeechMike)
		# and clipboard-write are needed by the page. Everything else is
		# explicitly disabled so a compromised script cannot elicit a
		# prompt for camera, USB, serial, geolocation, etc.
		# fullscreen=(self) is kept open for the legitimate UI fullscreen
		# path.
		#
		# F-72: enumerate newer policy-controlled features that default to
		# allow if omitted. browsing-topics / interest-cohort matter most
		# (Topics API enrols a privacy-focused app's origin in ad-interest
		# profiling unless explicitly denied); attribution-reporting and
		# private-state-tokens are likewise advertising-side features.
		# compute-pressure is a fingerprinting vector. unload=() prevents
		# legacy unload-event timing channels. clipboard-write=(self)
		# keeps the auto-copy feature working (sanitizeClipboardText
		# flow) while clipboard-read stays denied.
		# F-94: extend with newer advertising/ambient features that
		# default to allow if omitted (run-ad-auction,
		# join-ad-interest-group, shared-storage*, private-aggregation,
		# publickey-credentials-create, otp-credentials,
		# window-management, keyboard-map, digital-credentials-get,
		# captured-surface-control, deferred-fetch, storage-access,
		# wake-lock alias). Also tightens fullscreen from (self) to ()
		# since no first-party code calls requestFullscreen.
		Permissions-Policy "accelerometer=(), ambient-light-sensor=(), attribution-reporting=(), autoplay=(), battery=(), bluetooth=(), browsing-topics=(), camera=(), captured-surface-control=(), clipboard-read=(), clipboard-write=(self), compute-pressure=(), deferred-fetch=(), digital-credentials-get=(), display-capture=(), document-domain=(), encrypted-media=(), execution-while-not-rendered=(), execution-while-out-of-viewport=(), fullscreen=(), gamepad=(), geolocation=(), gyroscope=(), hid=(self), idle-detection=(), interest-cohort=(), join-ad-interest-group=(), keyboard-map=(), local-fonts=(), magnetometer=(), microphone=(self), midi=(), otp-credentials=(), payment=(), picture-in-picture=(), private-aggregation=(), private-state-token-issuance=(), private-state-token-redemption=(), publickey-credentials-create=(), publickey-credentials-get=(), run-ad-auction=(), screen-wake-lock=(), serial=(), shared-storage=(), shared-storage-select-url=(), speaker-selection=(), storage-access=(), unload=(), usb=(), wake-lock=(), web-share=(), window-management=(), xr-spatial-tracking=()"
		# Belt-and-braces clickjacking defense alongside frame-ancestors 'none'
		# in CSP, for legacy browsers that ignore frame-ancestors.
		X-Frame-Options "DENY"
		# no-referrer: room ID + secret live in the URL hash (never sent in
		# Referer), but the path /remote-mic.html and any future query
		# parameters would otherwise leak to umami, HuggingFace and other
		# cross-origin sub-resources. The site needs no referrer information
		# from outside, so close the channel entirely.
		Referrer-Policy "no-referrer"
		# Forbid MIME-sniffing so a content-type-confusion attack against the
		# operator-supplied dictation regex CSV or any future user-uploaded
		# asset cannot escalate into script execution on a quirky browser.
		X-Content-Type-Options "nosniff"
		# HSTS. TLS is normally terminated by the outer reverse proxy, which
		# should already set this; setting it here as belt-and-braces means
		# the header reaches clients even if the outer proxy is misconfigured.
		# Browsers ignore HSTS over plain HTTP, so the in-container plain
		# :5173 listener can carry it harmlessly. Default 1 year, no preload
		# (operators must opt in to the preload list deliberately).
		#
		# F-70: includeSubDomains is OPT-IN via VITE_HSTS_SUFFIX. Defaulting
		# it ON would permanently brick every sibling subdomain that still
		# serves plain HTTP (legacy admin panel, internal status page, CI
		# artifact host, etc.) for any visitor who opens parakeet even once;
		# clients can only undo HSTS via chrome://net-internals per browser,
		# making the operator mistake one-way and visitor-facing. Operators
		# who own the full apex can opt in by setting
		# VITE_HSTS_SUFFIX="; includeSubDomains" (or add "; preload" only
		# after submitting to the HSTS preload list, which is irrevocable).
		# F-145: default max-age raised from 1y (31536000) to 2y (63072000)
		# to match Chrome/Firefox HSTS preload-list requirements. Operators
		# who need a different value still override via VITE_HSTS_MAX_AGE.
		Strict-Transport-Security "max-age={$VITE_HSTS_MAX_AGE:63072000}{$VITE_HSTS_SUFFIX:}"
		# Cross-Origin-Resource-Policy: keep our resources to same-origin.
		# COEP require-corp is already on; CORP same-origin is the matching
		# response-side guarantee so sibling subdomains cannot read our
		# config.js / model files / fonts via cross-origin fetches.
		Cross-Origin-Resource-Policy "same-origin"
	}

	# ── Cache policy ──────────────────────────────────────────────────────
	# Vite emits content-hashed filenames under /assets/ (e.g.
	# main-Dg503GNh.js). Their bytes are bound to the filename, so they
	# can be cached forever: a new build emits new filenames and the
	# referencing HTML changes too. Mark them immutable so browsers and
	# intermediate caches don't re-validate on every reload.
	@hashed path /assets/*
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	# HTML entry points and the runtime /config.js MUST never be served
	# stale. After a deploy, a user reusing a cached index.html (which
	# references the OLD hashed asset names that no longer exist) would
	# silently break. Same for /config.js when the operator changes envs:
	# a stale cache would keep the old VITE_ANALYTICS_URL / SRI hash /
	# model revision in play across container restarts.
	@html {
		path / /index.html /remote-mic.html
	}
	header @html Cache-Control "no-cache, must-revalidate"
	header /config.js Cache-Control "no-cache, must-revalidate"

	# F-75: the asset-integrity manifest is the trust anchor for the
	# F-38/F-50 SRI chain (verifiedAddModule + ORT WASM hash check). A
	# stale cached manifest paired with a freshly deployed asset can
	# either DoS recording (false integrity failure: cached old hash,
	# new bytes) or hide tampering (the cached manifest never sees the
	# new pin). build-sums.txt is the operator-side deploy-verification
	# anchor (env.example documents the diff workflow) and must also
	# never be served stale. Both files are tiny, revalidation is cheap.
	#
	# F-76: pcm-recorder-worklet.js sits at a STABLE URL (AudioWorklet
	# loads it by string path) so the immutable @hashed rule doesn't
	# match. Heuristic browser caching of the previous worklet against
	# the freshly deployed asset-integrity.json triggers F-38b's hash
	# mismatch and breaks recording until the cache evicts. Must
	# revalidate on every load.
	#
	# F-110: /ort/manifest.json is the F-38a trust anchor for the ORT
	# WASM blobs. It sits at a stable URL and the same stale-pair
	# concern applies: a deploy that rolls onnxruntime-web ships new
	# WASM bytes alongside a new manifest pinning their hashes; a
	# browser that has the old manifest cached then hash-checks the
	# new WASM against the old pin and fails. Same one-line fix as
	# the worklet pair.
	#
	# F-143: the symmetric half. The manifest pins a sha384 of each
	# `.wasm`/`.mjs` blob; if those are heuristically cached at stable
	# URLs while the manifest is revalidated, the old WASM hashes
	# against the new pin and recording fails closed. Pin the runtime
	# blobs to no-cache too so the pair always rolls together.
	@integrity {
		path /.well-known/asset-integrity.json /.well-known/build-sums.txt /pcm-recorder-worklet.js /ort/manifest.json /ort/*.wasm /ort/*.mjs
	}
	header @integrity Cache-Control "no-cache, must-revalidate"

	# F-146: every other static path was relying on RFC 7234 browser
	# heuristic freshness (Last-Modified-based, typically 10% of age), so
	# cache policy was unreviewable and contributed to the F-143 class of
	# stale-after-deploy failures for non-WASM assets (eruda-loader, the
	# dictation regex CSVs). Pin the policy explicitly:
	#  - /js/*, /favicon.svg: short-lived, must-revalidate (5 min). Catches
	#    eruda-loader rotation without spamming revalidations.
	#  - /dictation-regex/*: no-cache, must-revalidate so a regex-source
	#    update reaches users on the next page load.
	#  - /models/*: large (hundreds of MB) and the JS layer content-hashes
	#    them on use, so they can be heuristically cached for a day, but
	#    pin the rule so the intent is reviewable.
	@stable_static path /js/* /favicon.svg
	header @stable_static Cache-Control "public, max-age=300, must-revalidate"
	@dictation_regex path /dictation-regex/*
	header @dictation_regex Cache-Control "no-cache, must-revalidate"
	@local_models path /models/*
	header @local_models Cache-Control "public, max-age=86400, must-revalidate"

	# Signaling: strip /api/signal prefix → /api on the local Node sidecar.
	#
	# `header_up -X-Forwarded-For` removes any X-Forwarded-For the client
	# supplied before Caddy's reverse_proxy appends its own. Without this,
	# Caddy's default APPEND behaviour would leave the attacker-supplied
	# entry leftmost, and Node (with `trust proxy: 'loopback'`) honours
	# the leftmost entry as req.ip - giving the attacker a one-line
	# bypass of every per-IP rate limiter. Same treatment for X-Real-IP
	# and X-Forwarded-Host to keep the upstream's view of the client
	# bound to what Caddy actually saw on the wire.
	handle_path /api/signal/* {
		rewrite * /api{uri}
		# F-74: signaling responses (offer/answer/stats/room) carry
		# transient handshake state and an activeRooms count that an
		# intermediate cache (corporate egress proxy, ISP cache) might
		# happily serve to the next requester on the same path, building
		# a room-existence/activity oracle (related to F-43). No-store
		# also keeps the back-button / bfcache from restoring a stale
		# answer body. Pragma covers HTTP/1.0 intermediates. Vary on
		# X-Room-Secret ensures any cache that does retain bytes keys on
		# the secret rather than just the URL.
		header Cache-Control "no-store"
		header Pragma "no-cache"
		header Vary "Origin, X-Room-Secret"
		reverse_proxy localhost:3001 {
			# F-39: strip XFF/X-Real-IP/X-Forwarded-Host before Caddy
			# re-appends its own values; without this, client-supplied
			# values would leak to Express via trust proxy: 'loopback'
			# and forge req.ip past the rate limiter.
			header_up -X-Forwarded-For
			header_up -X-Real-IP
			header_up -X-Forwarded-Host
			# F-73: the same hygiene applies to the RFC 7239 Forwarded
			# header and to X-Forwarded-Proto/Port. Express doesn't
			# parse Forwarded today, but any future middleware
			# (`forwarded` npm package, app.set('trust proxy', true))
			# would suddenly honour an attacker-supplied
			# `Forwarded: for=8.8.8.8` and forge req.ip exactly the
			# way F-39 was meant to close. Force-set them to Caddy's
			# view so they cannot smuggle attacker state.
			header_up -Forwarded
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Port {server_port}
			# F-144: belt-and-braces fingerprint suppression. The signaling
			# server already calls app.disable('x-powered-by'); strip the
			# header at the edge too so any future Express middleware that
			# re-adds it gets caught before reaching the client.
			header_down -X-Powered-By
		}
	}

	# Local model fallback files: served from whatever host folder the operator
	# bind-mounted into the container at LOCAL_MODEL_PATH (flat layout — the
	# ONNX files and vocab.txt are expected directly inside that folder).
	handle_path /models/* {
		root * {$LOCAL_MODEL_PATH:/models}
		file_server
	}

	# Dictation regex CSVs (entrypoint populates /var/regex from URL or local folder).
	handle_path /dictation-regex/* {
		root * /var/regex
		file_server
	}

	# Runtime VITE_* config (entrypoint writes /run/config/config.js).
	# /srv is read-only at runtime, so config.js is served from a tmpfs path.
	handle /config.js {
		root * /run/config
		file_server
	}

	# SPA fallback is scoped to actual page routes. Asset-shaped paths
	# (/assets/*, /ort/*, /js/*, /pcm-recorder-worklet.js, etc.) bypass
	# the try_files fallback and return a real 404 from file_server if
	# the file is missing. Without this scoping, a stale-HTML deploy
	# would serve index.html (Content-Type text/html) under an
	# /assets/main-OLD.js URL: nosniff blocks execution and the page
	# silently breaks. More importantly, the fallback used to hide
	# genuine 404s on legitimate asset paths, masking deploy errors.
	@asset_path path /assets/* /ort/* /js/* /pcm-recorder-worklet.js
	handle @asset_path {
		root * /srv
		file_server
	}

	# SPA + remote-mic.html (Vite emits both as separate entry points).
	handle {
		root * /srv
		try_files {path} {path}/ /index.html
		file_server
	}
}
