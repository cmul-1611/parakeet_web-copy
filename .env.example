# Vite Development Server Configuration
VITE_ALLOWED_HOST=your-domain.com,your-other-domain.com
VITE_USE_POLLING=true

# Analytics Configuration (optional - remove or leave empty to disable)
VITE_ANALYTICS_URL=https://your-umami-instance.com/getinfo
VITE_ANALYTICS_WEBSITE_ID=your-website-id-here

# Model Configuration
VITE_MODEL_REPO=istupakov/parakeet-tdt-0.6b-v3-onnx

# Local model fallback: when enabled, the UI can serve model weights directly
# from this instance (under /models/) if HuggingFace is unreachable.
# To use:
#   1. pip install huggingface-hub
#   2. hf download istupakov/parakeet-tdt-0.6b-v3-onnx --local-dir ./fallback_models/istupakov__parakeet-tdt-0.6b-v3-onnx
#   3. Uncomment the volume bind in docker-compose.yml
#   4. Uncomment the line below
# VITE_LOCAL_MODEL_FALLBACK=true
