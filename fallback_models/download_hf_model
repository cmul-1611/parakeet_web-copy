#!/usr/bin/env bash
# Downloads a HuggingFace model repo locally so it can be bind-mounted
# into the container as a local fallback (served under /models/).
#
# Usage:
#   ./download_hf_model --repo <owner/model-name>
#
# Example:
#   ./download_hf_model --repo istupakov/parakeet-tdt-0.6b-v3-onnx
#
# Requirements: huggingface-cli  (pip install huggingface-hub)

set -euo pipefail

REPO=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      REPO="$2"
      shift 2
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "Usage: $0 --repo <owner/model-name>" >&2
      exit 1
      ;;
  esac
done

if [[ -z "$REPO" ]]; then
  echo "Error: --repo is required." >&2
  echo "Usage: $0 --repo <owner/model-name>" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TARGET_DIR="${SCRIPT_DIR}/${REPO}"

echo "Downloading ${REPO} into ${TARGET_DIR} ..."
mkdir -p "$TARGET_DIR"

huggingface-cli download "$REPO" --local-dir "$TARGET_DIR"

echo ""
echo "Done. Model files saved to: ${TARGET_DIR}"
echo "Now uncomment the fallback volume and env var in docker-compose.yml."
